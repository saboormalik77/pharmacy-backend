# Copy to edge-secrets.env (gitignored) and fill in values.
#
# CLI cannot set SUPABASE_* secret names. To store URL/keys/DB in the dashboard + push via CLI, use:
#   EDGE_SUPABASE_URL, EDGE_SUPABASE_ANON_KEY, EDGE_SUPABASE_SERVICE_ROLE_KEY, DATABASE_URL
# (Same values as Settings → API / Database. Must match the project you intend functions to use.)

# EDGE_SUPABASE_URL=https://YOUR_REF.supabase.co
# EDGE_SUPABASE_ANON_KEY=
# EDGE_SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# IMAP (read-ra-emails)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@example.com
# Use quotes if Gmail app password has spaces:
# IMAP_PASS="xxxx xxxx xxxx xxxx"

# SMTP (send-email, send-pharmacy-invite, send-branch-invite)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=
SMTP_FROM_EMAIL=you@example.com
SMTP_FROM_NAME=Returns Department

# Optional fallbacks (send-email, send-ra-email*)
FROM_EMAIL=you@example.com
REPLY_TO_EMAIL=you@example.com
CONTACT_NAME=Returns Department
CONTACT_EMAIL=you@example.com
CONTACT_PHONE=

# Azure OpenAI (read-ra-emails)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Portal links in invite emails
PHARMACY_PORTAL_URL=https://your-portal.example.com
MAIN_ADMIN_PORTAL_URL=https://your-mainadmin.example.com

# Resend (send-ra-email, send-ra-email-enhanced)
# RESEND_API_KEY=

# resend-webhook
# RESEND_WEBHOOK_SECRET=


# Railway Deployment Environment Variables
# Copy this file and configure these variables in your Railway project settings

# Required - Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Server Configuration
NODE_ENV=production
PORT=8080

# Optional - Contact Information
CONTACT_NAME=Returns Department
CONTACT_EMAIL=returns@fcr-system.com
CONTACT_PHONE=+1234567890

# Optional - API Configuration  
API_BASE_URL=https://your-railway-app.railway.app

# Optional - Email Configuration (if using SMTP)
SMTP_USER=your_smtp_user
REPLY_TO_EMAIL=your_reply_email

# Optional - Edge Function Configuration
EDGE_SUPABASE_URL=your_edge_supabase_url
EDGE_SUPABASE_ANON_KEY=your_edge_supabase_anon_key

# FedEx shipping (defaults to sandbox if FEDEX_API_URL is unset — labels show TEST LABEL / SAMPLE)
FEDEX_API_KEY=your_fedex_api_key
FEDEX_SECRET_KEY=your_fedex_secret_key
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number
# Sandbox (test labels): https://apis-sandbox.fedex.com
# Production (real labels):  https://apis.fedex.com
FEDEX_API_URL=https://apis.fedex.com
_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/page.tsx", "source_location": "L397"}, {"caller_nid": "returns_page_returnspage", "callee": "(() => {\n                                const totalPages = pagination.totalPages;\n                                const current = currentPage;\n                                const pages = [];\n                                \n                                if (totalPages <= 7) {\n                                    // Show all pages if 7 or fewer\n                                    for (let i = 1; i <= totalPages; i++) {\n                                        pages.push(i);\n                                    }\n                                } else {\n                                    // Always show first page\n                                    pages.push(1);\n                                    \n                                    if (current <= 4) {\n                                        // Show pages 1,2,3,4,5...last\n                                        for (let i = 2; i <= 5; i++) {\n                                            pages.push(i);\n                                        }\n                                        if (totalPages > 6) pages.push('...');\n                                        pages.push(totalPages);\n                                    } else if (current >= totalPages - 3) {\n                                        // Show pages 1...last-4,last-3,last-2,last-1,last\n                                        if (totalPages > 6) pages.push('...');\n                                        for (let i = totalPages - 4; i <= totalPages; i++) {\n                                            pages.push(i);\n                                        }\n                                    } else {\n                                        // Show pages 1...current-1,current,current+1...last\n                                        pages.push('...');\n                                        for (let i = current - 1; i <= current + 1; i++) {\n                                            pages.push(i);\n                                        }\n                                        pages.push('...');\n                                        pages.push(totalPages);\n                                    }\n                                }\n                                \n                                return pages.map((page, index) => \n                                    page === '...' ? (\n                                        <span key={`ellipsis-${index}`} className=\"px-2 py-1.5 text-sm text-[#9ca3af]\">...</span>\n                                    ) : (\n                                        <button\n                                            key={page}\n                                            onClick={() => setCurrentPage(page as number)}\n                                            className={`px-3 py-1.5 text-sm border rounded-[4px] transition-colors ${\n                                                page === current\n                                                    ? 'border-[#516057] bg-[#516057] text-white font-semibold'\n                                                    : 'border-[#e2e2e2] text-[#505454] hover:bg-[var(--surface-container)]'\n                                            }`}\n                                        >\n                                            {page}\n                                        </button>\n                                    )\n                                );\n                            })", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/page.tsx", "source_location": "L465"}, {"caller_nid": "returns_page_returnspage", "callee": "map", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/
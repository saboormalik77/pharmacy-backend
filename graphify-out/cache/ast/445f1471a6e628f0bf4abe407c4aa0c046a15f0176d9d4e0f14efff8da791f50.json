 storeBase = price * 0.70;\n        const pkgSize = parseFloat(form.fullPackageSize) || 0;\n        const qtyNum = parseFloat(form.fullPackageQtyReturned) || 0;\n\n        if (!form.fullPackageQtyReturned.trim() || qtyNum <= 0 || pkgSize <= 0) {\n            return Math.round(storeBase * 100) / 100;\n        }\n\n        const pct = form.qtyMode === 'units'\n            ? Math.min(100, (qtyNum / pkgSize) * 100)\n            : Math.min(100, qtyNum);\n\n        return Math.round(storeBase * (pct / 100) * 100) / 100;\n    })", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/admin/app/warehouse/returns/[id]/add-items/page.tsx", "source_location": "L189"}, {"caller_nid": "add_items_page_additemspage", "callee": "useCallback", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/admin/app/warehouse/returns/[id]/add-items/page.tsx", "source_location": "L209"}, {"caller_nid": "add_items_page_additemspage", "callee": "useCallback", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/admin/app/warehouse/returns/[id]/add-items/page.tsx", "source_location": "L342"}, {"caller_nid": "add_items_page_additemspage", "callee": "max", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/admin/app/warehouse/returns/[id]/add-items/page.tsx", "source_location": "L600"}, {"caller_nid": "add_items_page_additemspage", "callee": "ceil", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/admin/app/warehouse/returns/[id]/add-items/page.tsx", "source_location": "L600"}, {"caller_nid": "add_items_page_additemspage", "callee": "slice", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/admin/app/warehouse/returns/[id]/add-items/page.tsx", "source_location": "L601"}, {"caller_nid": "add_items_page_additemspage", "callee": "min", "is_member_cal
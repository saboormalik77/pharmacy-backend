.tsx", "source_location": "L221"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "(() => {\n    const price = parseFloat(form.standardPrice) || 0;\n    if (price <= 0) return 0;\n    const pkgSize = parseFloat(form.fullPackageSize) || 0;\n    const qtyNum = parseFloat(form.fullPackageQtyReturned) || 0;\n    if (!form.fullPackageQtyReturned.trim() || qtyNum <= 0 || pkgSize <= 0) return price;\n    const pct = form.qtyMode === 'units' ? Math.min(100, (qtyNum / pkgSize) * 100) : Math.min(100, qtyNum);\n    return price * (pct / 100);\n  })", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L226"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "(() => {\n    const price = parseFloat(form.standardPrice) || 0;\n    if (price <= 0) return 0;\n    const storeBase = price * 0.70;\n    const pkgSize = parseFloat(form.fullPackageSize) || 0;\n    const qtyNum = parseFloat(form.fullPackageQtyReturned) || 0;\n    if (!form.fullPackageQtyReturned.trim() || qtyNum <= 0 || pkgSize <= 0) {\n      return Math.round(storeBase * 100) / 100;\n    }\n    const pct = form.qtyMode === 'units' ? Math.min(100, (qtyNum / pkgSize) * 100) : Math.min(100, qtyNum);\n    return Math.round(storeBase * (pct / 100) * 100) / 100;\n  })", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L236"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "useCallback", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L249"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "useCallback", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L257"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "useEffect", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L278"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "map", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L620"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "map", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L666"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "map", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L724"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "trim", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L782"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "has", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L852"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "has", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L853"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "has", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L854"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "has", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L855"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "map", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L876"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "has", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L883"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "has", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L895"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "has", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L898"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "(() => {\n                const pkgSize = parseFloat(form.fullPackageSize) || 0;\n                const qtyNum = parseFloat(form.fullPackageQtyReturned) || 0;\n                let isPartialDerived = false;\n                let pctDerived = 0;\n                let unitsDerived = 0;\n                if (form.fullPackageQtyReturned.trim() && qtyNum > 0 && pkgSize > 0) {\n                  if (form.qtyMode === 'units') { unitsDerived = qtyNum; pctDerived = (qtyNum / pkgSize) * 100; }\n                  else { pctDerived = qtyNum; unitsDerived = (pctDerived / 100) * pkgSize; }\n                  isPartialDerived = unitsDerived < pkgSize && pctDerived < 100;\n                }\n                return (\n                  <>\n                    <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-2\">\n                      <div>\n                        <label className=\"block text-[10px] font-medium text-[#505454] mb-0.5\">Price ($)</label>\n                        <input type=\"number\" step=\"0.01\" min=\"0\" value={form.standardPrice} onChange={e => !scanFetching && updateField('standardPrice', e.target.value)} placeholder=\"0.00\" disabled={scanFetching} className={`w-full px-2 py-1 text-xs border border-[#e2e2e2] rounded-[4px] focus:outline-none focus:ring-1 focus:ring-[#516057] ${scanFetching ? 'border-[#e2e2e2] bg-[#f5f2f1] text-[#505454] cursor-not-allowed' : 'border-[#e2e2e2]'}`} />\n                      </div>\n                      <div>\n                        <label className=\"block text-[10px] font-medium text-[#505454] mb-0.5\">Pkg Size</label>\n                        <input type=\"number\" min=\"1\" value={form.fullPackageSize} onChange={e => !scanFetching && updateField('fullPackageSize', e.target.value)} placeholder=\"e.g. 60\" disabled={scanFetching} className={`w-full px-2 py-1 text-xs border border-[#e2e2e2] rounded-[4px] focus:outline-none focus:ring-1 focus:ring-[#516057] ${scanFetching ? 'border-[#e2e2e2] bg-[#f5f2f1] text-[#505454] cursor-not-allowed' : 'border-[#e2e2e2]'}`} />\n                      </div>\n                      <div>\n                        <label className=\"block text-[10px] font-medium text-[#505454] mb-0.5\">\n                          Qty Returned <span className=\"text-[#9ca3af]\">({form.qtyMode === 'units' ? 'units' : '%'})</span>\n                        </label>\n                        <div className=\"flex gap-1\">\n                          <input type=\"number\" min=\"0\" step=\"any\" value={form.fullPackageQtyReturned} onChange={e => { if (!scanFetching) updateField('fullPackageQtyReturned', e.target.value); }} placeholder={form.qtyMode === 'units' ? '45' : '75'} disabled={scanFetching} className={`flex-1 px-2 py-1 text-xs border border-[#e2e2e2] rounded-[4px] focus:outline-none focus:ring-1 focus:ring-[#516057] ${scanFetching ? 'border-[#e2e2e2] bg-[#f5f2f1] text-[#505454] cursor-not-allowed' : 'border-[#e2e2e2]'}`} />\n                          <button type=\"button\" onClick={() => !scanFetching && updateField('qtyMode', form.qtyMode === 'units' ? 'percent' : 'units')} disabled={scanFetching} className=\"px-1.5 text-[10px] font-semibold rounded border border-[#e2e2e2] bg-[#f5f2f1] hover:bg-[#e2e2e2] text-[#505454] transition-colors disabled:opacity-50 disabled:cursor-not-allowed\">\n                            {form.qtyMode === 'units' ? '#' : '%'}\n                          </button>\n                        </div>\n                        {form.fullPackageQtyReturned.trim() && qtyNum > 0 && pkgSize > 0 && (\n                          <p className=\"text-[10px] mt-0.5 font-medium text-green-600\">\n                            {isPartialDerived ? `Partial \u2014 ${pctDerived.toFixed(1)}% (${unitsDerived.toFixed(1)} units)` : 'Full bottle'}\n                          </p>\n                        )}\n                      </div>\n                    </div>\n                    <div className=\"grid grid-cols-2 gap-2 mt-2\">\n                      <div>\n                        <label className=\"block text-[10px] font-medium text-[#505454] mb-0.5\">Est. Value</label>\n                        <input type=\"text\" readOnly value={`$${estimatedValue.toFixed(2)}`} className=\"w-full px-2 py-1 text-xs border border-[#e2e2e2] rounded bg-[#f5f2f1] text-[#505454] font-medium\" />\n                      </div>\n                      <div>\n                        <label className=\"block text-[10px] font-medium text-[#505454] mb-0.5\">Est. Store Value <span className=\"text-[#9ca3af] font-normal\">(-30%)</span></label>\n                        <input type=\"text\" readOnly value={`$${estimatedStoreValue.toFixed(2)}`} className=\"w-full px-2 py-1 text-xs border border-[#e2e2e2] rounded bg-[#f5f2f1] text-[#505454] font-medium\" />\n                      </div>\n                    </div>\n                  </>\n                );\n              })", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L905"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "replace", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L978"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "map", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L985"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "map", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L1003"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "map", "is_member_call": true, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L1026"}, {"caller_nid": "scan_page_pharmacyscanpage", "callee": "(() => {\n                  const noPolicy = !policyAutoCheck || policyAutoCheck.status === 'tbd';\n                  const isManualNonReturnable = noPolicy && form.returnStatus === 'non_returnable';\n                  return isManualNonReturnable ? (\n                    <>\n                      {nonReturnableRoute === 'wine_cellar' && (\n                        <div className=\"mb-2 bg-purple-50 border border-purple-200 rounded px-3 py-2 space-y-2\">\n                          <div className=\"flex items-start gap-1.5\">\n                            <Archive className=\"w-3.5 h-3.5 text-purple-600 mt-0.5 flex-shrink-0\" />\n                            <div>\n                              <p className=\"text-xs font-semibold text-purple-800\">Wine Cellar route selected</p>\n                              <p className=\"text-[10px] text-purple-700 mt-0.5\">Enter expected returnable date, then move item to Wine Cellar.</p>\n                            </div>\n                          </div>\n                          <div>\n                            <label className=\"block text-[10px] font-medium text-purple-700 mb-0.5\">\n                              Expected Returnable Date <span className=\"text-red-500\">*</span>\n                            </label>\n                            <input\n                              type=\"date\"\n                              value={wineCellarDate}\n                              onChange={e => setWineCellarDate(e.target.value)}\n                              disabled={scanFetching}\n                              className={`w-44 px-2 py-1 text-xs border border-[#e2e2e2] rounded-[4px] focus:outline-none focus:ring-1 focus:ring-purple-400 ${scanFetching ? 'border-[#e2e2e2] bg-[#f5f2f1] cursor-not-allowed' : !wineCellarDate ? 'border-red-300 bg-red-50' : 'border-purple-300 bg-white'}`}\n                            />\n                          </div>\n                        </div>\n                      )}\n                      {nonReturnableRoute === 'destruction' && (\n                        <div className=\"mb-2 bg-red-50 border border-red-200 rounded px-3 py-2\">\n                          <div className=\"flex items-start gap-1.5\">\n                            <Ban className=\"w-3.5 h-3.5 text-red-600 mt-0.5 flex-shrink-0\" />\n                            <div>\n                              <p className=\"text-xs font-semibold text-red-800\">Destruction route selected</p>\n                              <p className=\"text-[10px] text-red-700 mt-0.5\">Item will be saved as non-returnable and routed to destruction workflow.</p>\n                            </div>\n                          </div>\n                        </div>\n                      )}\n                      <div className=\"flex flex-wrap gap-1.5\">\n                        {nonReturnableRoute === 'wine_cellar' ? (\n                          <button type=\"button\" onClick={handleMoveToWineCellarManual} disabled={scanFetching || isItemActionLoading || !wineCellarDate} className=\"inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded bg-purple-600 text-white hover:bg-purple-700 disabled:opacity-50 transition-colors\">\n                            {isItemActionLoading ? <><Loader2 className=\"w-3 h-3 animate-spin\" />Moving...</> : <><Archive className=\"w-3 h-3\" />Move to Wine Cellar</>}\n                          </button>\n                        ) : (\n                          <button type=\"button\" onClick={() => handleSave()} disabled={scanFetching || isItemActionLoading || isPreChecking} className=\"inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded bg-red-600 text-white hover:bg-red-700 disabled:opacity-50 transition-colors\">\n                            {isItemActionLoading || isPreChecking ? <><Loader2 className=\"w-3 h-3 animate-spin\" />Saving...</> : <><Ban className=\"w-3 h-3\" />Save to Destruction</>}\n                          </button>\n                        )}\n                        <button type=\"button\" onClick={resetForm} disabled={scanFetching} className=\"inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded border border-[#e2e2e2] text-[#505454] hover:bg-[#f5f2f1] transition-colors disabled:opacity-50 disabled:cursor-not-allowed\">\n                          <X className=\"w-3 h-3\" /> Clear\n                        </button>\n                      </div>\n                    </>\n                  ) : (\n                    <div className=\"flex flex-wrap gap-1.5\">\n                      <button type=\"button\" onClick={() => handleSave()} disabled={scanFetching || isItemActionLoading || isPreChecking || (!form.ndc && !form.proprietaryName)} className=\"inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded bg-[#516057] text-white hover:bg-[#505454] disabled:opacity-50 transition-colors\">\n                        {isItemActionLoading || isPreChecking\n                          ? <><Loader2 className=\"w-3 h-3 animate-spin\" />{isPreChecking ? 'Checking...' : 'Saving...'}</>\n                          : <><CheckCircle className=\"w-3 h-3\" />Save &amp; Scan Next</>}\n                      </button>\n                      <button type=\"button\" onClick={resetForm} disabled={scanFetching} className=\"inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded border border-[#e2e2e2] text-[#505454] hover:bg-[#f5f2f1] transition-colors disabled:opacity-50 disabled:cursor-not-allowed\">\n                        <RotateCcw className=\"w-3 h-3\" /> Clear\n                      </button>\n                      <button type=\"button\" onClick={() => router.push('/returns')} className=\"inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded text-[#6b7280] hover:bg-[#f5f2f1] transition-colors\">\n                        <X className=\"w-3 h-3\" /> Cancel\n                      </button>\n                    </div>\n                  );\n                })", "is_member_call": false, "source_file": "/home/saboor.malik@2bvision.com/2bvt/pharmacy-backend/Frontend/app/(dashboard)/returns/scan/page.tsx", "source_location": "L1078"}]}